    )
    (class kicad_default +3V3 /BTN1 /BTN2 /BTN3 /LED_DB1 /LED_DB2 /LED_DB3
      GND "Net-(LED3-A)" "Net-(LED4-A)" "Net-(LED5-A)"
      (circuit
