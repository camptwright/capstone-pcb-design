
(rules PCB fsae_pcb.dsn
  (snap_angle 
    fortyfive_degree
  )
  (autoroute_settings
    (fanout on)
    (autoroute on)
    (postroute on)
    (vias on)
    (via_costs 50)
    (plane_via_costs 5)
    (start_ripup_costs 100)
    (start_pass_no 1)
    (layer_rule F.Cu
      (active on)
      (preferred_direction horizontal)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.6)
    )
    (layer_rule B.Cu
      (active on)
      (preferred_direction vertical)
      (preferred_direction_trace_costs 1.0)
      (against_preferred_direction_trace_costs 3.4)
    )
  )
  (rule
    (width 200.0)
    (clearance 200.0)
    (clearance 100.0 (type smd_to_turn_gap))
    (clearance 100.0 (type smd))
    (clearance 200.0 (type "kicad_default"))
  )
  (padstack "Via[0-1]_600:300_um"
    (shape
      (circle F.Cu 600.0 0.0 0.0)
    )
    (shape
      (circle B.Cu 600.0 0.0 0.0)
    )
    (attach off)
  )
  (via 
    "Via[0-1]_600:300_um" "Via[0-1]_600:300_um" default
  )
  (via 
    "Via[0-1]_600:300_um-kicad_default" "Via[0-1]_600:300_um" "kicad_default"
  )
  (via_rule
    default "Via[0-1]_600:300_um"
  )
  (via_rule
    "kicad_default" "Via[0-1]_600:300_um-kicad_default"
  )
  (class default
    (clearance_class default)
    (via_rule default)
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
  (class "kicad_default"
    GND "Net-(U1-OSC1)" "Net-(U1-OSC2)" +3V3 "Net-(U3-EN)" "Net-(U2-Vref)" +5V "Net-(U3-BST)"
    "Net-(D2-K)" "Net-(U3-COMP)" +12V "Net-(D1-K)" "/SPI_CE0" /BTN1 "/GPS_RX" /BTN3
    "unconnected-(J1-Pin_36-Pad36)" "unconnected-(J1-Pin_40-Pad40)" "unconnected-(J1-Pin_5-Pad5)" "unconnected-(J1-Pin_28-Pad28)" "unconnected-(J1-Pin_38-Pad38)" "unconnected-(J1-Pin_31-Pad31)" "/LED_DB3" "unconnected-(J1-Pin_32-Pad32)"
    "unconnected-(J1-Pin_26-Pad26)" /BTN2 "/SPI_MISO" "unconnected-(J1-Pin_33-Pad33)" "unconnected-(J1-Pin_35-Pad35)" "unconnected-(J1-Pin_7-Pad7)" "/SPI_MOSI" "/SPI_SCK"
    "/MCP_INT" "unconnected-(J1-Pin_27-Pad27)" "/LED_DB2" "/LED_DB1" "/GPS_TX" "unconnected-(J1-Pin_3-Pad3)" "unconnected-(J1-Pin_12-Pad12)" "unconnected-(J1-Pin_37-Pad37)"
    /SDA /SCL "Net-(J4-Pin_2)" "Net-(J4-Pin_1)" "/DIP_USB_DP" "/DISP_USB_DM" "Net-(LED1-A)" "Net-(LED2-K)"
    "Net-(U1-~{RX0BF})" "Net-(U1-~{RESET})" "Net-(U3-FB)" "unconnected-(U1-~{TX0RTS}-Pad4)" "Net-(U1-RXCAN)" "unconnected-(U1-~{RX1BF}-Pad10)" "unconnected-(U1-~{TX1RTS}-Pad5)" "Net-(U1-TXCAN)"
    "unconnected-(U1-CLKOUT{slash}SOF-Pad3)"
    (clearance_class "kicad_default")
    (via_rule "kicad_default")
    (rule
      (width 200.0)
    )
    (circuit 
      (use_layer F.Cu B.Cu)
    )
  )
)